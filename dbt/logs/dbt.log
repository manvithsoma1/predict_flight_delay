[0m09:09:36.039554 [debug] [Thread-1 (]: On model.flight_delay.mart_delay_summary: /* {"app": "dbt", "dbt_version": "1.11.6", "profile_name": "flight_delay", "target_name": "dev", "node_id": "model.flight_delay.mart_delay_summary"} */

  
    

  create  table "flightdb_local"."public_mart"."mart_delay_summary__dbt_tmp"
  
  
    as
  
  (
    -- mart_delay_summary.sql
-- Final aggregated table pushed to Neon DB for dashboard
-- Very small: ~500 rows total — fits easily in 512MB Neon limit



WITH features AS (
    SELECT * FROM "flightdb_local"."public_intermediate"."int_flight_features"
),

airline_summary AS (
    SELECT
        'airline'                                AS dimension,
        airline_iata                             AS dimension_value,
        COUNT(*)                                 AS total_flights,
        SUM(is_delayed)                          AS delayed_flights,
        ROUND(AVG(is_delayed::FLOAT) * 100, 1)  AS delay_rate_pct,
        ROUND(AVG(departure_delay_min), 1)       AS avg_delay_min
    FROM features
    WHERE airline_iata IS NOT NULL
    GROUP BY airline_iata
),

airport_summary AS (
    SELECT
        'airport'                                AS dimension,
        origin_airport                           AS dimension_value,
        COUNT(*)                                 AS total_flights,
        SUM(is_delayed)                          AS delayed_flights,
        ROUND(AVG(is_delayed::FLOAT) * 100, 1)  AS delay_rate_pct,
        ROUND(AVG(departure_delay_min), 1)       AS avg_delay_min
    FROM features
    WHERE origin_airport IS NOT NULL
    GROUP BY origin_airport
),

hour_summary AS (
    SELECT
        'hour'                                   AS dimension,
        scheduled_hour::TEXT                     AS dimension_value,
        COUNT(*)                                 AS total_flights,
        SUM(is_delayed)                          AS delayed_flights,
        ROUND(AVG(is_delayed::FLOAT) * 100, 1)  AS delay_rate_pct,
        ROUND(AVG(departure_delay_min), 1)       AS avg_delay_min
    FROM features
    WHERE scheduled_hour IS NOT NULL
    GROUP BY scheduled_hour
),

month_summary AS (
    SELECT
        'month'                                  AS dimension,
        month::TEXT                              AS dimension_value,
        COUNT(*)                                 AS total_flights,
        SUM(is_delayed)                          AS delayed_flights,
        ROUND(AVG(is_delayed::FLOAT) * 100, 1)  AS delay_rate_pct,
        ROUND(AVG(departure_delay_min), 1)       AS avg_delay_min
    FROM features
    WHERE month IS NOT NULL
    GROUP BY month
)

SELECT * FROM airline_summary
UNION ALL
SELECT * FROM airport_summary
UNION ALL
SELECT * FROM hour_summary
UNION ALL
SELECT * FROM month_summary

ORDER BY dimension, delay_rate_pct DESC
  );
  
